---
import type { BlogCategory, BlogCover } from '../../types/index'
import PostMeta from './PostMeta.astro'
import TagPill from './TagPill.astro'
import Icon from '../ui/Icon.astro'

interface Props {
  title: string
  description: string
  excerpt: string
  href: string
  publishedAt: Date
  updatedAt?: Date
  category: BlogCategory
  tags?: string[]
  cover?: BlogCover
}

const { title, description, excerpt, href, publishedAt, updatedAt, category, tags, cover } = Astro.props
---

<article class="featured-post" data-reveal>
  <a href={href} class="featured-post__link">
    {cover && (
      <figure class="featured-post__figure">
        <img
          src={cover.src}
          alt={cover.alt}
          loading="eager"
          class="featured-post__img"
        />
      </figure>
    )}
    <div class="featured-post__body">
      <div class="featured-post__badge">
        <Icon name="bxs-star" /> Destacado
      </div>
      <PostMeta publishedAt={publishedAt} updatedAt={updatedAt} category={category} />
      <h2 class="featured-post__title">{title}</h2>
      <p class="featured-post__description">{description || excerpt}</p>
      {tags && tags.length > 0 && (
        <div class="featured-post__tags">
          {tags.map(tag => <TagPill tag={tag} />)}
        </div>
      )}
      <span class="featured-post__read">
        Leer artículo <Icon name="bx-right-arrow-alt" class="featured-post__arrow" />
      </span>
    </div>
  </a>
</article>

<style>
.featured-post {
  background: var(--surface-1);
  border: 1px solid var(--card-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition:
    transform var(--transition-base),
    box-shadow var(--transition-base),
    border-color var(--transition-base);
}

.featured-post:hover,
.featured-post:focus-within {
  transform: translateY(-2px);
  box-shadow: var(--shadow-medium);
  border-color: var(--primary-color-alpha);
}

.featured-post__link {
  display: grid;
  grid-template-columns: 1fr;
  text-decoration: none;
  color: inherit;
  min-height: 30rem;
}

@media (min-width: 768px) {
  .featured-post__link {
    grid-template-columns: 1fr 1fr;
  }
}

.featured-post__figure {
  margin: 0;
  overflow: hidden;
  aspect-ratio: 16 / 9;
  background: var(--surface-2);
}

@media (min-width: 768px) {
  .featured-post__figure {
    aspect-ratio: unset;
  }
}

.featured-post__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform var(--transition-slow);
}

.featured-post:hover .featured-post__img {
  transform: scale(1.02);
}

.featured-post__body {
  display: flex;
  flex-direction: column;
  gap: 1.4rem;
  padding: 2.8rem 3.2rem;
}

.featured-post__badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 1.2rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--primary-color);
}

.featured-post__title {
  font-size: 2.4rem;
  font-weight: 700;
  color: var(--title-color);
  line-height: 1.3;
  letter-spacing: -0.02em;
  margin: 0;
}

@media (min-width: 768px) {
  .featured-post__title {
    font-size: 3rem;
  }
}

.featured-post__description {
  font-size: 1.6rem;
  color: var(--text-color);
  line-height: 1.7;
  margin: 0;
  flex: 1;
}

.featured-post__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6rem;
}

.featured-post__read {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 1.4rem;
  font-weight: 500;
  color: var(--primary-color);
  margin-top: auto;
}

.featured-post__arrow {
  font-size: 1.8rem;
  transition: transform var(--transition-fast);
}

.featured-post:hover .featured-post__arrow {
  transform: translateX(4px);
}
</style>
