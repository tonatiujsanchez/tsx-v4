---
import { navItems } from '@data/navigation'
import ThemeToggle from './ThemeToggle.astro'
import Icon from '../ui/Icon.astro'

interface Props {
  variant?: 'home' | 'project'
  backHref?: string
}

const { variant = 'home', backHref = '/' } = Astro.props
const currentPath = Astro.url.pathname
const isHome = currentPath === '/'
const resolveHref = (href: string) =>
  href.startsWith('#') && !isHome ? `/${href}` : href
const isActive = (href: string) => href.startsWith('/') && !href.startsWith('/#') && currentPath === href
---

<header class="header" data-variant={variant}>
  <div class="navbar container container--wide">
    {variant === 'home' ? (
      <>
        <a class="navbar__logo" href={resolveHref('#')} aria-label="Inicio" data-testid="navbar-logo">
          <img
            class="navbar__logo-img"
            src="/favicon/logo-ts.svg"
            alt="TSX"
            width="30"
            height="30"
          />
        </a>
        <nav class="nav">
          <ul class="nav__list" role="list">
            {navItems.map((item) => (
              <li class:list={['nav__item', { 'nav__item--mobile-only': item.mobileOnly, 'nav__item--desktop-only': item.desktopOnly }]}>
                <a
                  href={resolveHref(item.href)}
                  aria-label={item.ariaLabel}
                  class:list={['nav__link', { 'nav__link--active': isActive(item.href) }]}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                >
                  <Icon name={item.icon} class="nav__link-icon" />
                  <span class="nav__link-text">{item.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </>
    ) : (
      <a href={backHref} class="nav__back" data-testid="navbar-back">
        <Icon name="bx-arrow-back" />
        <span>Regresar</span>
      </a>
    )}

    <ThemeToggle />
  </div>
</header>
<div class="header__progress" aria-hidden="true"></div>

<script>
  import { initNavObserver } from '@scripts/navbar'
  const header = document.querySelector<HTMLElement>('.header')
  if (header?.dataset.variant === 'home') {
    initNavObserver()
  }
</script>

<style>
  .header {
    position: relative;
    z-index: 20;
  }

  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 1.5rem;
  }

  .navbar__logo {
    display: flex;
    align-items: center;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  .navbar__logo:hover {
    transform: scale(1.06);
    opacity: 0.85;
  }

  .navbar__logo-img {
    height: 2.8rem;
    width: auto;
  }

  /* Mobile: floating bottom nav pill */
  .nav {
    position: fixed;
    inset-block-end: 1.2rem;
    inset-inline: 1.2rem;
    background: var(--backdrop-surface);
    backdrop-filter: var(--backdrop-blur);
    -webkit-backdrop-filter: var(--backdrop-blur);
    border: var(--card-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-medium);
    z-index: 30;
  }

  .nav__list {
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 0;
    padding-block: 1.6rem;
    padding-inline: 1.6rem;
    margin-inline: auto;
    max-width: 40rem;
    list-style: none;
  }

  @media (min-width: 768px) {
    .nav__item--mobile-only {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .nav__item--desktop-only {
      display: none;
    }
  }

  .nav__link {
    position: relative;
    font-weight: 400;
    font-size: 2.2rem;
    display: flex;
    align-items: center;
    color: var(--text-muted);
    transition: color var(--transition-fast);
  }

  .nav__link:hover {
    color: var(--title-color);
  }

  :global(.nav__link--active) {
    color: var(--primary-color) !important;
  }

  .nav__link-text {
    display: none;
  }

  .nav__back {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-color);
    font-size: 1.5rem;
    font-weight: 500;
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  .nav__back:hover {
    color: var(--primary-color);
    transform: translateX(-2px);
  }

  .header__progress {
    display: none;
  }

  /* ── Desktop ── */
  @media (min-width: 768px) {
    .header {
      position: sticky;
      inset-block-start: 0;
      background: var(--backdrop-surface);
      backdrop-filter: var(--backdrop-blur);
      -webkit-backdrop-filter: var(--backdrop-blur);
      border-block-end: var(--border-subtle);
    }

    .navbar {
      padding-block: 1.6rem;
    }

    .nav {
      position: static;
      background: none;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border: none;
      border-radius: 0;
      box-shadow: none;
    }

    .nav__list {
      padding: 0;
      gap: 2.8rem;
      max-width: none;
      margin-inline: 0;
    }

    .nav__link {
      font-weight: 400;
      font-size: 1.5rem;
      color: var(--text-color);
      padding-block: 0.4rem;
    }

    .nav__link::after {
      content: '';
      position: absolute;
      inset-block-end: 0;
      inset-inline-start: 0;
      width: 100%;
      height: 1.5px;
      background: var(--primary-color);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform var(--transition-base);
    }

    .nav__link:hover::after {
      transform: scaleX(1);
    }

    :global(.nav__link--active)::after {
      transform: scaleX(1) !important;
    }

    .nav__link-text {
      display: inline-flex;
    }

    :global(.nav__link-icon) {
      display: none;
    }

    .header__progress {
      display: block;
      position: fixed;
      inset-block-start: 0;
      inset-inline-start: 0;
      height: 2px;
      width: calc(var(--scroll-progress, 0) * 1%);
      background: linear-gradient(to right, rgba(211, 115, 78, 0.4), var(--primary-color));
      pointer-events: none;
      z-index: 40;
      transition: width 80ms linear;
    }
  }
</style>
