---
import type { Job } from '@ptypes/index'

interface Props {
  job: Job
}

const { job } = Astro.props
---

<article class="job" data-reveal>
  {job.logo && (
    <figure class="job__logo">
      <img
        src={job.logo}
        alt={`Logo de ${job.company}`}
        width="48"
        height="48"
        loading="lazy"
      />
    </figure>
  )}
  <div class="job__card">
    <div class="job__meta">
      <h3 class="job__title">{job.title}</h3>
      <p class="job__company">{job.company}</p>
    </div>
    <span class="job__period">{job.period}</span>
  </div>
</article>

<style>
  .job {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 1.8rem;
    padding-block-end: 2.4rem;
  }

  .job:last-child {
    padding-block-end: 0;
  }

  .job__logo {
    position: relative;
    z-index: 1;
    flex: none;
    width: 4.8rem;
    height: 4.8rem;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--surface-2);
    border: var(--border-normal);
    box-shadow: 0 0 0 4px var(--body-color);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .job:hover .job__logo {
    border-color: rgba(211, 115, 78, 0.4);
    box-shadow: 0 0 0 4px var(--body-color), 0 0 16px rgba(211, 115, 78, 0.2);
  }

  .job__logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .job__card {
    flex: 1;
    min-width: 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.2rem;
    padding: 1.4rem 1.8rem;
    background: var(--surface-1);
    border: var(--card-border);
    border-radius: var(--radius-lg);
    transition:
      transform var(--transition-fast),
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .job:hover .job__card {
    transform: translateX(4px);
    border-color: rgba(211, 115, 78, 0.25);
    box-shadow: var(--shadow-medium);
  }

  .job__meta {
    flex: 1;
    min-width: 0;
  }

  .job__title {
    font-weight: 600;
    font-size: 1.6rem;
    color: var(--title-color);
    line-height: 1.3;
  }

  .job__company {
    font-size: 1.4rem;
    color: var(--text-muted);
    margin-block-start: 0.3rem;
    text-wrap: pretty;
  }

  .job__period {
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--primary-color);
    background: var(--primary-color-alpha);
    padding: 0.3rem 1rem;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(211, 115, 78, 0.2);
    white-space: nowrap;
    flex: none;
  }

  @media (max-width: 480px) {
    .job__card {
      flex-direction: column;
      gap: 0.8rem;
    }
  }
</style>
