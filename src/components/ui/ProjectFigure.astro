---
interface Props {
  src: string
  alt: string
  caption?: string
  transitionName?: string
}

const { src, alt, caption, transitionName } = Astro.props
---

<figure class="project-figure" data-reveal>
  <div class="project-figure__frame">
    <img
      class="project-figure__img"
      src={src}
      alt={alt}
      loading="lazy"
      transition:name={transitionName}
    />
  </div>
  {caption && <figcaption class="project-figure__caption">{caption}</figcaption>}
</figure>

<style>
  .project-figure {
    margin-block-end: 4rem;
    transition: transform var(--transition-base);
  }

  .project-figure:hover {
    transform: translateY(-2px);
  }

  .project-figure__frame {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface-1);
    border: var(--card-border);
    box-shadow: var(--card-shadow);
    margin-block-end: 1rem;
    transition: box-shadow var(--transition-base);
  }

  .project-figure:hover .project-figure__frame {
    box-shadow: var(--shadow-strong);
  }

  .project-figure__img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .project-figure__caption {
    font-size: 1.4rem;
    color: var(--text-muted);
    padding-inline: 0.4rem;
    line-height: 1.5;
    text-wrap: pretty;
  }
</style>
