---
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import BlogLayout from '../../layouts/BlogLayout.astro'
import PostHeader from '../../components/blog/PostHeader.astro'
import RelatedPosts from '../../components/blog/RelatedPosts.astro'
import { siteConfig } from '../../data/site'
import { getRelatedPosts } from '../../utils/blog'

export async function getStaticPaths() {
  const isDev = import.meta.env.DEV
  const posts = await getCollection('blog', ({ data }) => isDev || !data.draft)
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }))
}

interface Props {
  post: CollectionEntry<'blog'>
  allPosts: CollectionEntry<'blog'>[]
}

const { post, allPosts } = Astro.props
const { Content } = await render(post)

const {
  title,
  description,
  publishedAt,
  updatedAt,
  category,
  tags,
  cover,
  ogImage,
  canonical: postCanonical,
  author,
} = post.data

const canonical = postCanonical ?? `${siteConfig.url}/blog/${post.id}`
const ogImageUrl = ogImage ?? cover?.src

const related = getRelatedPosts(post.id, allPosts).map(p => ({
  title: p.data.title,
  description: p.data.description,
  href: `/blog/${p.id}`,
  publishedAt: p.data.publishedAt,
  category: p.data.category,
  tags: p.data.tags,
}))

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: publishedAt.toISOString(),
  ...(updatedAt ? { dateModified: updatedAt.toISOString() } : {}),
  author: {
    '@type': 'Person',
    name: author ?? siteConfig.author,
    url: siteConfig.url,
  },
  url: canonical,
  ...(cover ? { image: `${siteConfig.url}${cover.src}` } : {}),
}
---

<BlogLayout
  title={`${title} — ${siteConfig.author}`}
  description={description}
  canonical={canonical}
  ogImage={ogImageUrl}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="post">
    <PostHeader
      title={title}
      description={description}
      publishedAt={publishedAt}
      updatedAt={updatedAt}
      category={category}
      tags={tags}
      cover={cover}
      author={author}
    />
    <div class="post-content container">
      <Content />
    </div>
    <div class="container">
      <RelatedPosts posts={related} />
    </div>
  </article>
</BlogLayout>

<style>
.post {
  padding-block-end: 8rem;
}

.post-content {
  max-width: 70rem;
  margin: 4rem auto 0;
}

/* ── Headings ─────────────────────────────────────────── */

.post-content :global(h2) {
  font-size: 2.4rem;
  font-weight: 700;
  color: var(--title-color);
  letter-spacing: -0.01em;
  line-height: 1.3;
  margin: 5.2rem 0 1.6rem;
  padding-block-end: 1rem;
  border-block-end: 1px solid var(--border-subtle);
}

.post-content :global(h3) {
  font-size: 2rem;
  font-weight: 600;
  color: var(--title-color);
  line-height: 1.35;
  margin: 3.6rem 0 1.2rem;
}

.post-content :global(h4) {
  font-size: 1.75rem;
  font-weight: 600;
  color: var(--title-color);
  line-height: 1.4;
  margin: 2.8rem 0 1rem;
}

.post-content :global(h2:first-child),
.post-content :global(h3:first-child),
.post-content :global(h4:first-child) {
  margin-block-start: 0;
}

/* ── Body text ────────────────────────────────────────── */

.post-content :global(p) {
  font-size: 1.7rem;
  color: var(--text-color);
  line-height: 1.85;
  margin: 0 0 2rem;
  text-wrap: pretty;
}

.post-content :global(strong) {
  color: var(--title-color);
  font-weight: 600;
}

.post-content :global(em) {
  font-style: italic;
  color: var(--text-muted);
}

/* ── Lists ────────────────────────────────────────────── */

.post-content :global(ul),
.post-content :global(ol) {
  font-size: 1.7rem;
  color: var(--text-color);
  line-height: 1.8;
  padding-inline-start: 2.4rem;
  margin: 0 0 2rem;
}

.post-content :global(li) {
  margin-block-end: 0.6rem;
}

.post-content :global(li > ul),
.post-content :global(li > ol) {
  margin-block-start: 0.4rem;
  margin-block-end: 0;
}

/* ── Links ────────────────────────────────────────────── */

.post-content :global(a) {
  color: var(--primary-color);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-thickness: 1px;
  transition: opacity var(--transition-fast);
}

.post-content :global(a:hover) {
  opacity: 0.8;
}

/* ── Code inline ──────────────────────────────────────── */

.post-content :global(code) {
  background: var(--surface-2);
  color: var(--primary-color);
  padding: 0.15em 0.5em;
  border-radius: var(--radius-xs);
  font-size: 0.88em;
  font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace;
  border: 1px solid var(--border-subtle);
}

/* ── Code blocks ──────────────────────────────────────── */

.post-content :global(pre) {
  background: var(--surface-2);
  border: 1px solid var(--border-normal);
  border-radius: var(--radius-md);
  padding: 2rem 2.4rem;
  overflow-x: auto;
  margin: 0 0 2.4rem;
  -webkit-overflow-scrolling: touch;
}

.post-content :global(pre code) {
  background: none;
  color: var(--text-color);
  padding: 0;
  font-size: 1.5rem;
  line-height: 1.75;
  border: none;
  font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace;
  tab-size: 2;
}

/* ── Blockquotes / Callouts ───────────────────────────── */

.post-content :global(blockquote) {
  border-inline-start: 3px solid var(--primary-color);
  border: 1px solid var(--border-subtle);
  border-inline-start-width: 3px;
  border-inline-start-color: var(--primary-color);
  background: var(--surface-1);
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  padding: 1.6rem 2rem 1.6rem 2.4rem;
  margin: 0 0 2.4rem;
}

.post-content :global(blockquote p) {
  margin: 0;
  font-size: 1.6rem;
  color: var(--text-color);
}

.post-content :global(blockquote p strong:first-child) {
  color: var(--primary-color);
  font-weight: 700;
}

/* ── Separator ────────────────────────────────────────── */

.post-content :global(hr) {
  border: none;
  border-block-start: 1px solid var(--border-subtle);
  margin: 4.8rem 0;
}

/* ── Tables ───────────────────────────────────────────── */

.post-content :global(table) {
  display: block;
  width: max-content;
  max-width: 100%;
  overflow-x: auto;
  border-collapse: collapse;
  font-size: 1.5rem;
  line-height: 1.6;
  margin: 0 0 2.4rem;
  -webkit-overflow-scrolling: touch;
}

.post-content :global(th) {
  background: var(--surface-2);
  color: var(--title-color);
  font-weight: 600;
  padding: 0.8rem 1.4rem;
  text-align: left;
  border: 1px solid var(--border-normal);
  white-space: nowrap;
}

.post-content :global(td) {
  color: var(--text-color);
  padding: 0.8rem 1.4rem;
  border: 1px solid var(--border-subtle);
  vertical-align: top;
}

.post-content :global(tr:nth-child(even) td) {
  background: var(--surface-1);
}

/* ── Native markdown images ───────────────────────────── */

.post-content :global(img) {
  display: block;
  max-width: 100%;
  height: auto;
  border-radius: var(--radius-lg);
  border: 1px solid var(--card-border);
  margin: 2.4rem auto;
}

.post-content :global(figure) {
  margin: 2.4rem 0;
}

.post-content :global(figcaption) {
  font-size: 1.4rem;
  color: var(--text-muted);
  text-align: center;
  margin-block-start: 0.8rem;
  line-height: 1.5;
}
</style>
